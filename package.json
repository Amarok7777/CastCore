{
  "name": "splitflow",
  "version": "0.1.0",
  "description": "OBS Speedrun Timer — Electron app with live overlay",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:portable": "electron-builder --win portable --x64"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.7.2",
    "jsmediatags": "^3.9.7",
    "obs-websocket-js": "^5.0.6",
    "uiohook-napi": "^1.5.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.castcore.app",
    "productName": "CastCore",
    "asar": false,
    "afterPack": "./scripts/afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "core/**/*",
      "server/**/*",
      "tools/**/*",
      "launcher/**/*",
      "scenepilot/**/*",
      "tunapilot/**/*",
      "splitflow/**/*",
      "settings/**/*",
      "widgeturls/**/*",
      "flowforge/**/*",
      "controldeck/**/*",
      "chatdeck/**/*",
      "alertdeck/**/*",
      "shared/**/*",
      "data/oauthClients.json",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CastCore"
    },
    "publish": {
      "provider": "github",
      "owner": "DEIN_GITHUB_USERNAME",
      "repo": "DEIN_REPO_NAME"
    }
  }
}
